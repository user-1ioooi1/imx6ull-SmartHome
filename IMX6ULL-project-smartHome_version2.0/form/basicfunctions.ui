   <property name="styleSheet">
    <string notr="true">QSlider::handle:horizontal {
    width: 15px;   /* 把手宽度调大 */
    height: 60px;  /* 把手高度调大 */
    background: #2196F3;
    margin: -10px 0;  /* 让把手突出滑槽 */
    border-radius: 15px;
}

QSlider::groove:horizontal {
    height: 8px;    /* 滑槽厚度 */
    background: lightgray;
    border-radius: 4px;
}</string>
   </property>
   <property name="orientation">
    <enum>Qt::Horizontal</enum>
   </property>
  </widget>
